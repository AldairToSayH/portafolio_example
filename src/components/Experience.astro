---
import { experiences } from "../data/experience";
---

<section id="experience" class="section-padding">
  <div class="container-shell">
    <span class="section-eyebrow">Experiencia</span>
    <h2 class="section-title">Experiencia práctica en soporte técnico y bases de datos dentro de un entorno profesional.</h2>
    <p class="section-copy">Enfoque en disponibilidad de datos, soporte interno, asistencia de infraestructura y mejora de procesos.</p>

    <div class="mt-12 grid gap-6">
      {experiences.map((experience) => (
        <article class="glass-panel relative overflow-hidden rounded-[2rem] p-6 sm:p-8">
          <div class="absolute left-0 top-0 h-full w-1 bg-gradient-to-b from-violet-300 via-purple-400 to-fuchsia-400"></div>
          <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
            <div>
              <p class="text-sm font-bold uppercase tracking-[0.22em] text-violet-200">{experience.period}</p>
              <h3 class="mt-4 font-display text-2xl font-bold text-white">{experience.role}</h3>
              <p class="mt-2 text-lg font-semibold text-slate-200">{experience.company}</p>
              <p class="mt-2 text-sm text-slate-400">{experience.location}</p>
            </div>
            <ul class="grid gap-3 text-sm leading-7 text-slate-300 sm:text-base">
              {experience.description.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-2 w-2 flex-none rounded-full bg-violet-300 shadow-glow"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
