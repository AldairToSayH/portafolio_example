---
import { projects } from "../data/projects";
---

<section id="projects" class="section-padding relative overflow-hidden">
  <div class="absolute right-0 top-12 -z-10 h-96 w-96 rounded-full bg-violet-500/10 blur-3xl"></div>
  <div class="container-shell">
    <span class="section-eyebrow">Proyectos</span>
    <h2 class="section-title">Proyectos preparados para demos reales, repositorios y futuros casos de estudio.</h2>
    <p class="section-copy">Estas tarjetas están estructuradas para editar fácilmente enlaces, capturas y resultados cuando estén disponibles.</p>

    <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => (
        <article class="premium-card flex min-h-full flex-col">
          <div class="mb-5 flex items-start justify-between gap-4">
            <h3 class="font-display text-xl font-bold text-white">{project.title}</h3>
            <span class="badge flex-none text-violet-100">{project.status}</span>
          </div>
          <p class="text-sm leading-7 text-slate-300">{project.description}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {project.technologies.map((tech) => <span class="badge">{tech}</span>)}
          </div>
          <div class="mt-auto flex gap-3 pt-7">
            {project.demoUrl ? (
              <a href={project.demoUrl} target="_blank" rel="noreferrer" class="btn-secondary px-4 py-2">Demo</a>
            ) : (
              <span role="link" aria-disabled="true" class="inline-flex cursor-not-allowed items-center justify-center rounded-full border border-white/10 bg-white/[0.035] px-4 py-2 text-sm font-bold text-slate-500">Demo</span>
            )}
            {project.repoUrl ? (
              <a href={project.repoUrl} target="_blank" rel="noreferrer" class="btn-secondary px-4 py-2">Repositorio</a>
            ) : (
              <span role="link" aria-disabled="true" class="inline-flex cursor-not-allowed items-center justify-center rounded-full border border-white/10 bg-white/[0.035] px-4 py-2 text-sm font-bold text-slate-500">Repositorio</span>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
