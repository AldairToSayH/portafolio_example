---
import { profile } from "../data/profile";

const highlights = [
  { title: "Ciberseguridad", copy: "Fundamentos de seguridad, web pentesting y práctica de hacking ético." },
  { title: "Desarrollo de software", copy: "Herramientas web modernas, lógica backend y construcción de aplicaciones prácticas." },
  { title: "Datos y bases de datos", copy: "SQL Server, MySQL, organización de datos y gestión de bases de datos." },
  { title: "Soporte TI", copy: "Soporte de infraestructura, redes, resolución de incidencias y continuidad operativa." },
];
---

<section id="about" class="section-padding">
  <div class="container-shell">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <span class="section-eyebrow">Sobre mí</span>
        <h2 class="section-title">Un perfil técnico formado por curiosidad, disciplina y experiencia real en soporte.</h2>
        <p class="section-copy">{profile.profileSummary}</p>
        <p class="mt-5 text-base leading-7 text-slate-400">Radico en {profile.location} y actualmente estudio en {profile.university} como estudiante de {profile.semester}.</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {highlights.map((item) => (
          <article class="premium-card">
            <div class="mb-5 h-1 w-12 rounded-full bg-gradient-to-r from-violet-300 to-purple-400"></div>
            <h3 class="font-display text-xl font-bold text-white">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
