---
import MusicController from "./MusicController";
import ContactForm from "./ContactForm";
import { profile } from "../data/profile";
---

<section id="contact" class="section-padding relative overflow-hidden">
  <div class="absolute inset-x-0 bottom-0 -z-10 h-80 bg-gradient-to-t from-violet-400/10 to-transparent"></div>
  <div class="container-shell">
    <span class="section-eyebrow">Contacto</span>
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div>
        <h2 class="section-title">Conectemos para construir algo práctico, seguro y eficiente.</h2>
        <p class="section-copy">Estoy abierto a oportunidades académicas, profesionales y colaborativas relacionadas con ciberseguridad, desarrollo de software, bases de datos y soporte TI.</p>

        <div class="mt-8 glass-panel rounded-[2rem] p-6">
          <p class="text-sm leading-7 text-slate-300">Puedes escribirme directamente o revisar mis perfiles profesionales sin exponer datos sensibles en pantalla.</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <a class="btn-secondary" href={`mailto:${profile.email}`} aria-label="Enviar correo">
              Enviar correo
            </a>
            <a class="btn-secondary" href={profile.github} target="_blank" rel="noreferrer" aria-label="Abrir perfil de GitHub">
              Ver GitHub
            </a>
            <a class="btn-secondary" href={profile.linkedin} target="_blank" rel="noreferrer" aria-label="Abrir perfil de LinkedIn">
              Ver LinkedIn
            </a>
            <a class="btn-secondary" href={profile.whatsappUrl} target="_blank" rel="noreferrer" aria-label="Contactar por WhatsApp">
              WhatsApp
            </a>
          </div>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          <div class="premium-card p-5">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-violet-200">Ubicación</p>
            <p class="mt-2 text-lg font-semibold text-white">Editable</p>
          </div>
          <div class="premium-card p-5">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-violet-200">Perfil</p>
            <p class="mt-2 text-lg font-semibold text-white">Tecnología y seguridad</p>
          </div>
          <div class="premium-card p-5">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-violet-200">Estado</p>
            <p class="mt-2 text-lg font-semibold text-white">Disponible</p>
          </div>
        </div>
      </div>

      <div class="grid gap-5">
        <MusicController client:load />
        <ContactForm client:load recipient={profile.email} />
      </div>
    </div>
  </div>
</section>
